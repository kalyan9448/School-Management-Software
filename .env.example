# Environment Variables — School Management SaaS
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to source control.

# ── Google Gemini AI ──────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── Firebase ──────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Comma-separated list of emails that should get the 'superadmin' role on first login
# Any Firebase user NOT in this list defaults to 'admin'
VITE_SUPERADMIN_EMAILS=superadmin@yourdomain.com

# ── Backend API (Node.js/Express) ─────────────────────────────────────────────
# Leave empty to use demo mode (no backend required)
VITE_API_BASE_URL=http://localhost:3001

# ── Backend-only (set in backend/.env or process environment) ─────────────────
# Comma-separated emails that the backend assigns 'superadmin' role on login.
# Must mirror VITE_SUPERADMIN_EMAILS so the backend creates profiles correctly.
# SUPERADMIN_EMAILS=superadmin@yourdomain.com
