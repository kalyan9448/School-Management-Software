rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /student_avatars/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /teacher_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /parent_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /admin_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /superadmin_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
