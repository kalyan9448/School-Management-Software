rules_version = '2';

// =============================================================================
// Firestore Security Rules  --  School Management Software (Kidz Vision)
// =============================================================================
//
// ARCHITECTURE
// ------------
// The Express backend uses the Firebase Admin SDK and BYPASSES these rules.
// These rules govern ONLY the browser (Firebase client SDK v12).
//
// Role-based access is driven by Firebase Auth JWT custom claims:
//   { role: "superadmin" | "admin" | "accountant" | "teacher" | "parent" | "student",
//     school_id: "<schoolId>" }
//
// Custom claims are set exclusively by the backend Admin SDK in
// POST /api/auth/login.  The client calls getIdToken(true) immediately
// after login, so claims are present before any dashboard Firestore read.
// Clients can NEVER forge or modify custom claims.
//
// MULTI-TENANCY
// -------------
// Every school-scoped document contains a school_id field.
// Every school-scoped query includes where('school_id', '==', schoolId).
// These rules enforce that:
//   - Reads only return documents matching the user's school_id claim
//   - Writes only create/update documents with the user's school_id
//   - school_id cannot be changed after creation
//   - SuperAdmin bypasses school_id checks (platform-level access)
//
// ROLE HIERARCHY
// --------------
//   superadmin  -- Platform level.  Manages organisations and schools.
//   admin       -- School level.  Full data management for their school.
//   accountant  -- School level.  Fee collection and financial records.
//   teacher     -- School level.  Attendance, lessons, assignments, quizzes.
//   parent      -- School level read-only.  Own children only (UI-enforced).
//   student     -- School level read-only + own submissions and portal data.
//
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Role from Firebase Auth JWT custom claim (set by backend Admin SDK).
    function getRole() {
      return ("role" in request.auth.token) ? request.auth.token.role : "";
    }

    // Fallback: read the role directly from the user's Firestore profile.
    function getRoleFromDoc() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get("role", "") : "";
    }

    // Resolve role: custom claim first (zero cost), then Firestore doc fallback.
    function resolvedRole() {
      let claim = getRole();
      return (claim != null && claim != "") ? claim : getRoleFromDoc();
    }

    function isSuperAdmin() {
      return isSignedIn() && resolvedRole() == "superadmin";
    }

    function isAdminOrAbove() {
      return isSignedIn() && resolvedRole() in ["superadmin", "admin"];
    }

    function isFinanceStaff() {
      return isSignedIn() && resolvedRole() in ["superadmin", "admin", "accountant"];
    }

    function isStaff() {
      return isSignedIn()
        && resolvedRole() in ["superadmin", "admin", "accountant", "teacher"];
    }

    function isTeacher() {
      return isSignedIn() && resolvedRole() == "teacher";
    }

    function isStudent() {
      return isSignedIn() && resolvedRole() == "student";
    }

    function isParent() {
      return isSignedIn() && resolvedRole() == "parent";
    }

    function notSettingSuperAdminRole() {
      return !("role" in request.resource.data)
          || request.resource.data.role != "superadmin";
    }

    function preservesPrivilegedFields() {
      return request.resource.data.role      == resource.data.role
          && request.resource.data.email     == resource.data.email
          && request.resource.data.school_id == resource.data.school_id;
    }

    // -- Multi-tenancy helpers ------------------------------------------------

    function hasSchoolClaim() {
      return ("school_id" in request.auth.token)
          && request.auth.token.school_id is string
          && request.auth.token.school_id.size() > 0;
    }

    // Fallback: read school_id from the user's Firestore profile document.
    function getSchoolIdFromDoc() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get("school_id", "") : "";
    }

    // Resolve school_id: JWT claim first (zero cost), then Firestore doc fallback.
    function resolvedSchoolId() {
      return hasSchoolClaim() ? request.auth.token.school_id : getSchoolIdFromDoc();
    }

    // Guard: resolved school_id is valid (via JWT claim or Firestore doc)
    function hasValidSchoolId() {
      let sid = resolvedSchoolId();
      return sid is string && sid.size() > 0;
    }

    // The user's school_id from their JWT custom claim
    function userSchoolId() {
      return resolvedSchoolId();
    }

    // Existing document belongs to the user's school
    function isOwnSchool() {
      return resource.data.school_id == userSchoolId();
    }

    // New/updated document is tagged with the user's school
    function isOwnSchoolWrite() {
      return request.resource.data.school_id is string
          && request.resource.data.school_id.size() > 0
          && request.resource.data.school_id == userSchoolId();
    }

    // school_id is not being changed (prevents tenant hopping via update)
    function schoolIdUnchanged() {
      return request.resource.data.school_id == resource.data.school_id;
    }

    // Read access: superadmin sees all; others only their own school
    function canReadSchoolData() {
      return isSuperAdmin() || (hasValidSchoolId() && isOwnSchool());
    }

    // Create access: document must be tagged with user's school_id
    function canCreateSchoolData() {
      return isSuperAdmin() || (hasValidSchoolId() && isOwnSchoolWrite());
    }

    // Update access: school_id must match AND not be changed
    function canUpdateSchoolData() {
      return isSuperAdmin() || (hasValidSchoolId() && isOwnSchool() && schoolIdUnchanged());
    }

    // Delete access: document must belong to the user's school
    function canDeleteSchoolData() {
      return isSuperAdmin() || (hasValidSchoolId() && isOwnSchool());
    }

    // Any authenticated user who has a resolvable school (staff, teacher, parent, student).
    // Used as a belt-and-suspenders fallback when JWT school_id claim may not yet be set
    // (e.g. first login before getIdToken(true) completes).
    function isAnySchoolMember() {
      return isSignedIn() && (
          isSuperAdmin()
          || resolvedRole() in ["admin", "accountant", "teacher", "parent", "student"]
      );
    }

    // Read access for ALL school members (including students and parents).
    // Use this for collections that every school member should be able to read.
    function canReadSchoolDataAnyMember() {
      return isSuperAdmin()
          || (isAnySchoolMember() && hasValidSchoolId() && isOwnSchool());
    }


    // =========================================================================
    // STUDENT PORTAL  (per-user private storage -- completely isolated)
    // =========================================================================

    match /student_portal/{userId}/data/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }


    // =========================================================================
    // ORGANISATIONS  (platform-level -- superadmin only)
    // =========================================================================

    match /organizations/{orgId} {
      allow read, write: if isSuperAdmin();
    }


    // =========================================================================
    // SCHOOLS  (global entity -- read: any auth | write: superadmin only)
    // =========================================================================

    match /schools/{schoolId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }


    // =========================================================================
    // USER PROFILES  (global collection with optional school_id)
    // =========================================================================

    match /users/{userId} {
      // Single-doc read: own profile, superadmin, or same school
      allow get: if isSignedIn()
          && (
              isSuperAdmin()
              || userId == request.auth.uid
              || (hasValidSchoolId() && resource.data.school_id == userSchoolId())
          );

      // Query (list): superadmin, own school, or searching for own email (login migration)
      allow list: if isSignedIn()
          && (
              isSuperAdmin()
              || (hasValidSchoolId() && resource.data.school_id == userSchoolId())
              || resource.data.email == request.auth.token.email
          );

      // Create: self-write (first login) OR school-scoped staff write
      allow create: if isSignedIn()
          && notSettingSuperAdminRole()
          && (
              isSuperAdmin()
              || userId == request.auth.uid
              || (hasValidSchoolId()
                  && request.resource.data.school_id is string
                  && request.resource.data.school_id == userSchoolId())
          );

      // Update: self-update (preserving privileged fields) OR staff securely
      allow update: if isSignedIn()
          && notSettingSuperAdminRole()
          && (
              (userId == request.auth.uid)
              || isSuperAdmin()
              || (isStaff() && hasValidSchoolId() && isOwnSchool() && schoolIdUnchanged())
          );

      allow delete: if isSuperAdmin();
    }


    // =========================================================================
    // CLASSES
    // =========================================================================

    match /classes/{classId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // STUDENTS
    // =========================================================================

    match /students/{studentId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher()
        || (isStudent() && (
              request.auth.uid == studentId
              || resource.data.email == request.auth.token.email
           ))
        // Parent can read their own children: matched by parentId or by parentEmail
        || (isParent() && (
              resource.data.parentId == request.auth.uid ||
              resource.data.parentEmail == request.auth.token.email
           ))
        )
      );
      // Allow any authenticated user to find their own student record by email.
      // Needed on first login before role/school_id claims are set (chicken-and-egg).
      allow list: if isSignedIn()
          && resource.data.email == request.auth.token.email;
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // TEACHERS
    // =========================================================================

    match /teachers/{teacherId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || isParent())
      );
      // Allow a teacher to read their own record by email when school_id
      // claim is not yet available (e.g. first render after login).
      allow get: if isTeacher()
          && resource.data.email == request.auth.token.email;
      // Allow any authenticated user to find their own teacher record by email.
      // Needed on first login before role/school_id claims are set.
      allow list: if isSignedIn()
          && resource.data.email == request.auth.token.email;

      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());

      // Admins can update any teacher in their school.
      // Teachers can update their OWN record (e.g. profile photo, status)
      // but cannot change school_id or role.
      allow update: if isSuperAdmin()
          || (isAdminOrAbove() && canUpdateSchoolData())
          || (isTeacher()
              && resource.data.email == request.auth.token.email
              && schoolIdUnchanged()
              && (!("role" in request.resource.data) || request.resource.data.role == resource.data.role));

      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // TASKS (legacy — kept for backwards compatibility)
    // =========================================================================

    match /tasks/{taskId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // SUBJECTS
    // =========================================================================

    match /subjects/{subjectId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // SUBJECT MAPPINGS
    // =========================================================================
    
    match /subject_mappings/{mappingId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // LESSONS (lesson logs created by teachers)
    // =========================================================================

    match /lessons/{lessonId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // ASSIGNMENTS
    // =========================================================================

    match /assignments/{assignmentId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // ASSIGNMENT SUBMISSIONS
    // =========================================================================

    match /assignment_submissions/{submissionId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || isStudent() || isParent())
      );
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher() || isStudent()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // EXAMS
    // =========================================================================

    match /exams/{examId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // EXAM RESULTS
    // =========================================================================

    match /exam_results/{resultId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || isStudent() || isParent())
      );
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // EXAM SCORES (Teacher Marks Upload)
    // =========================================================================

    match /exam_scores/{scoreId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || 
         (isStudent() && resource.data.studentId == request.auth.uid) ||
         (isParent() && existsInStudentList()))
      );
      
      allow create: if isSuperAdmin() || (
        (isAdminOrAbove() || isTeacher()) && 
        canCreateSchoolData() &&
        request.resource.data.school_id == getSchoolId()
      );
      
      allow update: if isSuperAdmin() || (
        (isAdminOrAbove() || isTeacher()) && 
        canUpdateSchoolData() &&
        resource.data.school_id == request.resource.data.school_id
      );
      
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // QUIZZES
    // =========================================================================

    match /quizzes/{quizId} {
      // Students and parents can read quizzes.
      allow read: if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // QUIZ ATTEMPTS
    // =========================================================================

    match /quiz_attempts/{attemptId} {
      allow create: if isSuperAdmin() || (
        isStudent() && 
        request.resource.data.student_id == request.auth.uid && 
        hasValidSchoolId() && isOwnSchoolWrite()
      );

      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || (isStudent() && resource.data.student_id == request.auth.uid))
      );

      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // QUIZ RESULTS
    // =========================================================================

    match /quiz_results/{resultId} {
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || isTeacher() || isStudent() || isParent())
      );
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher() || isStudent()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // ATTENDANCE
    // =========================================================================

    match /attendance/{attendanceId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canCreateSchoolData());
      allow update: if isSuperAdmin() || ((isAdminOrAbove() || isTeacher()) && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // FEE PAYMENTS
    // =========================================================================

    match /fee_payments/{paymentId} {
      allow read:   if isSuperAdmin() || (isFinanceStaff() && canReadSchoolData())
                    || ((isStudent() || isParent()) && hasValidSchoolId() && isOwnSchool());
      allow create: if isSuperAdmin() || (isFinanceStaff() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isFinanceStaff() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // FEE STRUCTURES
    // =========================================================================

    match /fee_structures/{structureId} {
      allow read:   if isSuperAdmin() || (isFinanceStaff() && canReadSchoolData())
                    || ((isStudent() || isParent()) && hasValidSchoolId() && isOwnSchool());
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // FEE INVOICES
    // =========================================================================

    match /fee_invoices/{invoiceId} {
      allow read:   if isSuperAdmin() || (isFinanceStaff() && canReadSchoolData())
                    || ((isStudent() || isParent()) && hasValidSchoolId() && isOwnSchool());
      allow create: if isSuperAdmin() || (isFinanceStaff() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isFinanceStaff() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // PAYMENTS (legacy — kept for backwards compatibility)
    // =========================================================================

    match /payments/{paymentId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // ANNOUNCEMENTS
    // =========================================================================

    match /announcements/{announcementId} {
      // All school members (including students and parents) can read announcements.
      allow read: if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // ENQUIRIES
    // =========================================================================

    match /enquiries/{enquiryId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // ADMISSIONS
    // =========================================================================

    match /admissions/{admissionId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // CALENDAR & EVENTS
    // =========================================================================

    match /calendar/{calendarId} {
      // All school members can read calendar events (holidays, school activities).
      allow read: if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // NOTIFICATIONS
    // =========================================================================

    match /notifications/{notificationId} {
      allow read: if isSuperAdmin()
          || (hasValidSchoolId() && isOwnSchool() && (isAdminOrAbove() || isTeacher() || isStudent() || isParent()))
          || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSuperAdmin() || (isStaff() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (
        (isStaff() && canUpdateSchoolData()) ||
        (isSignedIn() && resource.data.userId == request.auth.uid)
      );
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // TIMETABLE
    // =========================================================================

    match /timetable/{slotId} {
      // All school members can read timetable.
      // Fallback: teacher reads own slots by email match when JWT school_id is absent.
      allow read: if canReadSchoolDataAnyMember()
          || (isTeacher() && resource.data.teacherId == request.auth.token.email);

      // Only admins manage the master timetable.
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // SCHOOL SETTINGS
    // =========================================================================

    match /school_settings/{settingId} {
      allow read:   if isSuperAdmin() || (isAdminOrAbove() && canReadSchoolData());
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // ACADEMIC YEARS
    // =========================================================================

    match /academic_years/{yearId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // STUDENT ENROLLMENTS
    // =========================================================================

    match /student_enrollments/{enrollmentId} {
      allow read:   if canReadSchoolDataAnyMember();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    // =========================================================================
    // AUDIT LOGS (write via Admin SDK; admins can read)
    // =========================================================================
    
    match /audit_logs/{logId} {
      allow read:  if isSuperAdmin() || (isAdminOrAbove() && canReadSchoolData());
      allow write: if isSuperAdmin();
    }

    // =========================================================================
    // REPORTS & SCHEDULED REPORTS
    // =========================================================================

    match /school_admin_reports/{reportId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }

    match /school_admin_scheduled_reports/{reportId} {
      allow read:   if canReadSchoolData();
      allow create: if isSuperAdmin() || (isAdminOrAbove() && canCreateSchoolData());
      allow update: if isSuperAdmin() || (isAdminOrAbove() && canUpdateSchoolData());
      allow delete: if isSuperAdmin() || (isAdminOrAbove() && canDeleteSchoolData());
    }
    
    // =========================================================================
    // PLANS  (platform-level -- read: any auth | write: superadmin only)
    // =========================================================================

    match /plans/{planId} {
      allow read:                   if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }

    // =========================================================================
    // SUPPORT TICKETS  (School Admins manage their own; SuperAdmin sees all)
    // =========================================================================

    match /support_tickets/{ticketId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.school_id == userSchoolId());
      
      // School Admins can create tickets for their own school
      allow create: if isSignedIn() 
          && request.resource.data.school_id == userSchoolId()
          && request.resource.data.role == "admin";

      // SuperAdmin can update anything; School Admins can ONLY add responses to their own tickets
      allow update: if isSuperAdmin() 
          || (isSignedIn() 
              && resource.data.school_id == userSchoolId()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['responses', 'updatedAt'])
             );
             
      allow delete: if isSuperAdmin();
    }

    // =========================================================================
    // PARENT-TEACHER CHAT
    // =========================================================================

    match /conversations/{conversationId} {
      // Access allowed if the user is the parent or teacher in this conversation
      allow read: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        (resource.data.teacherEmail != null && resource.data.teacherEmail == request.auth.token.email) ||
        isSuperAdmin() ||
        (isAdminOrAbove() && isOwnSchool())
      );
      
      // Allow creation if the current user is either the parentId or teacherId
      allow create: if isSignedIn() && (
        request.resource.data.parentId == request.auth.uid || 
        request.resource.data.teacherId == request.auth.uid ||
        isSuperAdmin()
      );

      // Allow updates to lastMessage, updatedAt, and unread counts
      allow update: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        (resource.data.teacherEmail != null && resource.data.teacherEmail == request.auth.token.email) ||
        isSuperAdmin()
      );

      // Messages subcollection
      match /messages/{messageId} {
        // Read/write allowed if you have access to the parent conversation
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.parentId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.teacherId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.teacherEmail == request.auth.token.email ||
          isSuperAdmin()
        );
      }
    }

    // =========================================================================
    // TEACHER CLASS CHECK-INS
    // =========================================================================
    
    match /teacher_class_checkins/{checkinId} {
      // Teachers can read their own; Admins see all for their school
      allow read: if isSuperAdmin() || (
        hasValidSchoolId() && isOwnSchool() &&
        (isAdminOrAbove() || (isTeacher() && resource.data.teacherId.lower() == request.auth.token.email.lower()))
      );
      
      // Teachers can only create their own records
      allow create: if isSuperAdmin() || (
        isTeacher() && 
        canCreateSchoolData() &&
        request.resource.data.teacherId.lower() == request.auth.token.email.lower()
      );
      
      // Check-ins are immutable once recorded
      allow update, delete: if isSuperAdmin();
    }
    
    // =========================================================================
    // CATCH-ALL DENY
    // =========================================================================

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
